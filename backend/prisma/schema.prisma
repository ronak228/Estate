generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SALES_EXECUTIVE
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
}

enum InquirySource {
  WALK_IN
  PHONE_CALL
  WEBSITE
  WHATSAPP
  REFERRAL
  ADVERTISEMENT
  OTHER
}

enum InquiryStage {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT_SCHEDULED
  NEGOTIATION
  BOOKED
  NOT_INTERESTED
}

enum ActivityType {
  CREATED
  ASSIGNED
  REASSIGNED
  STAGE_CHANGED
  FOLLOW_UP_SCHEDULED
  FOLLOW_UP_COMPLETED
  NOTE_ADDED
  MARKED_NOT_INTERESTED
  // ─── Extended types (BUG-018) ─────────────────────────────────────────────
  QUOTATION_CREATED
  QUOTATION_DECISION_UPDATED
  NEGOTIATION_RECORDED
  SITE_VISIT_COMPLETED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  INTERACTION_LOGGED
  INQUIRY_UPDATED
  INQUIRY_QUALIFIED
}

// ─── Project & Unit Inventory Enums ──────────────────────────────────────────

enum ProjectStatus {
  UPCOMING
  UNDER_CONSTRUCTION
  READY_TO_MOVE
  COMPLETED
}

// ─── Module 2 Enums ───────────────────────────────────────────────────────────

enum InteractionType {
  CALL
  MEETING
  WHATSAPP
  EMAIL
  NOTE
}

enum SiteVisitStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  SOLD
}

// ─── Module 3 Enums ───────────────────────────────────────────────────────────

enum QuotationDecision {
  PENDING
  NEGOTIATING
  ACCEPTED
  REJECTED
}

// ─── Module 4 Enums ───────────────────────────────────────────────────────────

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

enum PaymentMode {
  CASH
  CHEQUE
  BANK_TRANSFER
  UPI
  CARD
  OTHER
}

enum DocumentType {
  BOOKING_FORM
  SIGNED_AGREEMENT
  ID_PROOF
  PAYMENT_PROOF
  OTHER
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Company {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique
  status       CompanyStatus @default(ACTIVE)
  email        String?
  phone        String?
  address      String?
  timezone     String        @default("Asia/Kolkata")
  currency     String        @default("INR")
  logoUrl      String?
  primaryColor String?
  users        User[]
  contacts     Contact[]
  projects     Project[]
  brokers      Broker[]
  inquiries    Inquiry[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model User {
  id                  String        @id @default(uuid())
  companyId           String?
  company             Company?      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  fullName            String
  email               String        @unique
  passwordHash        String
  role                Role
  phone               String?
  isActive            Boolean       @default(true)
  lastLoginAt         DateTime?
  assignedInquiries   Inquiry[]        @relation("InquiryAssignedTo")
  createdInquiries    Inquiry[]        @relation("InquiryCreatedBy")
  createdFollowUps    FollowUp[]
  performedActivities ActivityLog[]
  createdInteractions Interaction[]
  createdSiteVisits   SiteVisit[]
  createdQuotations   Quotation[]
  createdNegotiations Negotiation[]
  bookedBookings      Booking[]
  recordedPayments    BookingPayment[]
  uploadedDocuments   BookingDocument[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([companyId])
}

// ─── Module 1: Inquiry Management ────────────────────────────────────────────

model Contact {
  id             String        @id @default(uuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  fullName       String
  phone          String
  email          String?
  company_name   String?
  address        String?
  budgetMin      Int?
  budgetMax      Int?
  preferredArea  String?
  inquiries      Inquiry[]
  interactions   Interaction[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([companyId, phone])
}

model Project {
  id        String        @id @default(uuid())
  companyId String
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name      String
  location  String?
  status    ProjectStatus @default(UPCOMING)
  inquiries Inquiry[]
  units     Unit[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([companyId])
}

model Broker {
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name      String
  phone     String?
  company_name String?
  inquiries Inquiry[]
  createdAt DateTime  @default(now())

  @@index([companyId])
}

model Inquiry {
  id           String        @id @default(uuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contactId    String
  contact      Contact       @relation(fields: [contactId], references: [id])
  projectId    String?
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  brokerId     String?
  broker       Broker?       @relation(fields: [brokerId], references: [id], onDelete: SetNull)
  assignedToId String
  assignedTo   User          @relation("InquiryAssignedTo", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User          @relation("InquiryCreatedBy", fields: [createdById], references: [id])
  source       InquirySource
  stage        InquiryStage  @default(NEW)
  notes        String?
  followUps      FollowUp[]
  activities     ActivityLog[]
  interactions   Interaction[]
  siteVisits     SiteVisit[]
  quotations     Quotation[]
  negotiations   Negotiation[]
  booking        Booking?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([companyId])
  @@index([contactId])
  @@index([projectId])
  @@index([brokerId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([stage])
}

model FollowUp {
  id          String    @id @default(uuid())
  inquiryId   String
  inquiry     Inquiry   @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  completedAt DateTime?
  notes       String?
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([inquiryId])
  @@index([createdById])
  @@index([scheduledAt])
}

model ActivityLog {
  id            String       @id @default(uuid())
  inquiryId     String
  inquiry       Inquiry      @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  type          ActivityType
  description   String
  performedById String
  performedBy   User         @relation(fields: [performedById], references: [id])
  createdAt     DateTime     @default(now())

  @@index([inquiryId])
  @@index([performedById])
}

// ─── Module 2: Lead Qualification & Contact Management ────────────────────────

model Interaction {
  id          String          @id @default(uuid())
  contactId   String
  contact     Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  inquiryId   String?
  inquiry     Inquiry?        @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  type        InteractionType
  notes       String
  occurredAt  DateTime        @default(now())
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())

  @@index([contactId])
  @@index([inquiryId])
  @@index([createdById])
}

model SiteVisit {
  id          String          @id @default(uuid())
  inquiryId   String
  inquiry     Inquiry         @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  unitId      String?
  unit        Unit?           @relation(fields: [unitId], references: [id], onDelete: SetNull)
  scheduledAt DateTime
  status      SiteVisitStatus @default(SCHEDULED)
  notes       String?
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([inquiryId])
  @@index([unitId])
  @@index([createdById])
  @@index([status])
  @@index([scheduledAt])
}

// Unit — real implementation (replaces stub from Module 2 plan).
model Unit {
  id           String      @id @default(uuid())
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id])
  unitNumber   String
  width        Decimal     @db.Decimal(10, 4) // feet — 4dp for dimension precision
  length       Decimal     @db.Decimal(10, 4) // feet
  area         Decimal     @db.Decimal(14, 4) // sq. ft. — calculated: width × length
  pricePerSqFt Decimal     @db.Decimal(14, 2) // ₹ per sq. ft.
  basePrice    Decimal     @db.Decimal(14, 2) // calculated: area × pricePerSqFt
  status       UnitStatus  @default(AVAILABLE)
  siteVisits   SiteVisit[]
  quotations   Quotation[]
  bookings     Booking[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([projectId, unitNumber])
  @@index([status])
}

// ─── Module 3: Property Viewing & Proposal ────────────────────────────────────

model Quotation {
  id           String            @id @default(uuid())
  inquiryId    String
  inquiry      Inquiry           @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  unitId       String
  unit         Unit              @relation(fields: [unitId], references: [id], onDelete: Restrict)
  // Snapshot of Unit.price at quote creation time — never re-read live after creation.
  // A price change on the unit must NOT silently alter a quote already sent to a customer.
  basePrice    Decimal           @db.Decimal(14, 2)
  totalAmount  Decimal           @db.Decimal(14, 2)
  decision     QuotationDecision @default(PENDING)
  validUntil   DateTime?
  charges      QuotationCharge[]
  negotiations Negotiation[]
  bookings     Booking[]
  createdById  String
  createdBy    User              @relation(fields: [createdById], references: [id])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([inquiryId])
  @@index([unitId])
  @@index([createdById])
  @@index([decision])
}

model QuotationCharge {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  label       String    // e.g. "Registration Charges", "Maintenance Deposit"
  amount      Decimal   @db.Decimal(14, 2)

  @@index([quotationId])
}

// ─── Module 4: Sales Negotiation & Booking ────────────────────────────────────

model Negotiation {
  id             String     @id @default(uuid())
  inquiryId      String
  inquiry        Inquiry    @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  quotationId    String?
  quotation      Quotation? @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  offeredPrice   Decimal           @db.Decimal(14, 2)
  discountAmount Decimal           @default(0) @db.Decimal(14, 2)
  notes          String?
  createdById    String
  createdBy      User       @relation(fields: [createdById], references: [id])
  createdAt      DateTime   @default(now())

  @@index([inquiryId])
  @@index([quotationId])
  @@index([createdById])
}

model Booking {
  id               String          @id @default(uuid())
  inquiryId        String          @unique
  inquiry          Inquiry         @relation(fields: [inquiryId], references: [id], onDelete: Restrict)
  quotationId      String
  quotation        Quotation       @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  unitId           String
  unit             Unit            @relation(fields: [unitId], references: [id], onDelete: Restrict)
  finalAmount      Decimal         @db.Decimal(14, 2)
  discountAmount   Decimal         @default(0) @db.Decimal(14, 2)
  bookingAmount    Decimal         @db.Decimal(14, 2)
  status           BookingStatus   @default(CONFIRMED)
  erpSyncedAt      DateTime?
  erpSalesOrderRef String?
  bookedById       String
  bookedBy         User            @relation(fields: [bookedById], references: [id])
  payments         BookingPayment[]
  documents        BookingDocument[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([quotationId])
  @@index([unitId])
  @@index([bookedById])
  @@index([status])
}

model BookingPayment {
  id              String      @id @default(uuid())
  bookingId       String
  booking         Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount          Decimal     @db.Decimal(14, 2)
  mode            PaymentMode
  paidAt          DateTime
  referenceNumber String?
  createdById     String
  createdBy       User        @relation(fields: [createdById], references: [id])
  createdAt       DateTime    @default(now())

  @@index([bookingId])
  @@index([createdById])
}

model BookingDocument {
  id           String       @id @default(uuid())
  bookingId    String
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  type         DocumentType
  fileName     String
  fileUrl      String
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime     @default(now())

  @@index([bookingId])
  @@index([uploadedById])
}
